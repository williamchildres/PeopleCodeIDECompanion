<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PeopleCodeIDECompanion.Views.PagePeopleCodeBrowserView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PeopleCodeIDECompanion.Views"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    MinWidth="1240"
    MinHeight="720"
    mc:Ignorable="d">

    <Grid RowSpacing="10"
          ColumnSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <InfoBar x:Name="InlineErrorInfoBar"
                 Grid.Row="0"
                 IsClosable="False"
                 IsOpen="False"
                 Severity="Error" />

        <Grid Grid.Row="1"
              ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.4*"
                                  MinWidth="220" />
                <ColumnDefinition Width="3.1*"
                                  MinWidth="280" />
                <ColumnDefinition Width="6.5*"
                                  MinWidth="620" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    MinHeight="420"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Pages"
                               Style="{ThemeResource SubtitleTextBlockStyle}" />

                    <TextBox x:Name="PageSearchTextBox"
                             Grid.Row="1"
                             PlaceholderText="Search pages"
                             TextChanged="PageSearchTextBox_TextChanged" />

                    <ListView x:Name="PagesListView"
                              Grid.Row="2"
                              SelectionChanged="PagesListView_SelectionChanged"
                              SelectionMode="Single"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled" />

                    <TextBlock x:Name="NoPagesTextBlock"
                               Grid.Row="3"
                               Visibility="Collapsed"
                               Text="No pages found."
                               TextWrapping="WrapWholeWords"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    MinHeight="420"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Page Items / Events"
                               Style="{ThemeResource SubtitleTextBlockStyle}" />

                    <TextBox x:Name="ItemSearchTextBox"
                             Grid.Row="1"
                             PlaceholderText="Search page items, events, or object keys"
                             TextChanged="ItemSearchTextBox_TextChanged" />

                    <ListView x:Name="ItemsListView"
                              Grid.Row="2"
                              SelectionChanged="ItemsListView_SelectionChanged"
                              SelectionMode="Single"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Padding="8"
                                            Spacing="4">
                                    <TextBlock Text="{Binding DisplayName}"
                                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                                               TextWrapping="WrapWholeWords" />
                                    <TextBlock Text="{Binding SecondaryLabel}"
                                               TextWrapping="WrapWholeWords"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <TextBlock x:Name="NoItemsTextBlock"
                               Grid.Row="3"
                               Visibility="Collapsed"
                               Text="No items found."
                               TextWrapping="WrapWholeWords"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </Grid>
            </Border>

            <Grid Grid.Column="2"
                  RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10">
                    <Grid RowSpacing="8"
                          ColumnSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Global Search"
                                   Style="{ThemeResource CaptionTextBlockStyle}" />

                        <TextBox x:Name="GlobalSourceSearchTextBox"
                                 Grid.Row="1"
                                 Grid.ColumnSpan="3"
                                 PlaceholderText="Search PeopleCode source across Page items"
                                 KeyDown="GlobalSourceSearchTextBox_KeyDown" />

                        <Button x:Name="GlobalSourceSearchButton"
                                Grid.Row="0"
                                Grid.Column="1"
                                Content="Search"
                                IsEnabled="False"
                                Click="GlobalSourceSearchButton_Click" />

                        <Button x:Name="ClearGlobalSearchButton"
                                Grid.Row="0"
                                Grid.Column="2"
                                Content="Clear"
                                IsEnabled="False"
                                Visibility="Collapsed"
                                Click="ClearGlobalSearchButton_Click" />

                        <InfoBar x:Name="GlobalSearchErrorInfoBar"
                                 Grid.Row="2"
                                 Grid.ColumnSpan="3"
                                 IsClosable="False"
                                 IsOpen="False"
                                 Severity="Error" />

                        <TextBlock x:Name="GlobalSearchStatusTextBlock"
                                   Grid.Row="3"
                                   Grid.ColumnSpan="3"
                                   Visibility="Collapsed"
                                   TextWrapping="WrapWholeWords"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <TextBlock x:Name="GlobalSearchLimitationTextBlock"
                                   Grid.Row="4"
                                   Grid.ColumnSpan="3"
                                   TextWrapping="WrapWholeWords"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="This first Page browser version reads PSPCMTXT/PSPCMPROG rows where OBJECTID1=9. It explicitly labels common Page Event and Page Record Field Event patterns and shows raw key metadata for other page-scoped shapes instead of guessing unsupported mappings." />
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10">
                    <local:PeopleCodeMetadataHeaderView x:Name="MetadataHeaderView" />
                </Border>

                <Border Grid.Row="2"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="10">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="PeopleCode Source"
                                       Style="{ThemeResource SubtitleTextBlockStyle}" />

                            <TextBlock x:Name="SourceMatchStatusTextBlock"
                                       Grid.Column="1"
                                       VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                            <Button x:Name="PreviousSourceMatchButton"
                                    Grid.Column="2"
                                    Content="Previous Match"
                                    IsEnabled="False"
                                    Click="PreviousSourceMatchButton_Click" />

                            <Button x:Name="NextSourceMatchButton"
                                    Grid.Column="3"
                                    Content="Next Match"
                                    IsEnabled="False"
                                    Click="NextSourceMatchButton_Click" />
                        </Grid>

                        <ScrollViewer x:Name="SourceScrollViewer"
                                      Grid.Row="1"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                            <RichTextBlock x:Name="SourceRichTextBlock"
                                           MinHeight="300"
                                           FontFamily="Consolas"
                                           IsTextSelectionEnabled="True"
                                           TextWrapping="NoWrap" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
