<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PeopleCodeIDECompanion.Views.OracleConnectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="24"
              RowSpacing="16"
              MaxWidth="720">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Spacing="8">
                <TextBlock Text="Oracle Connection"
                           Style="{ThemeResource TitleTextBlockStyle}" />
                <TextBlock Text="Enter connection details, save named profiles locally, then test or open the read-only App Package browser."
                           TextWrapping="WrapWholeWords"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <Border Grid.Row="1"
                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <Grid ColumnSpacing="12"
                      RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ComboBox Grid.Row="0"
                              Grid.Column="0"
                              x:Name="SavedConnectionsComboBox"
                              Header="Saved Connections"
                              DisplayMemberPath="DisplayName"
                              SelectionChanged="SavedConnectionsComboBox_SelectionChanged" />

                    <Button Grid.Row="0"
                            Grid.Column="1"
                            Content="Load"
                            Click="LoadSavedConnectionButton_Click" />

                    <Button Grid.Row="0"
                            Grid.Column="2"
                            Content="Delete"
                            Click="DeleteSavedConnectionButton_Click" />

                    <TextBox Grid.Row="1"
                             Grid.Column="0"
                             x:Name="DisplayNameTextBox"
                             Header="Profile Name"
                             PlaceholderText="HR Demo"
                             TextChanged="ConnectionInputChanged" />

                    <Button Grid.Row="1"
                            Grid.Column="1"
                            Grid.ColumnSpan="2"
                            Content="Save Current"
                            Click="SaveConnectionButton_Click" />
                </Grid>
            </Border>

            <Grid Grid.Row="2"
                  ColumnSpacing="16"
                  RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBox Grid.Row="0"
                         Grid.Column="0"
                         x:Name="HostTextBox"
                         Header="Host"
                         PlaceholderText="db.example.com"
                         TextChanged="ConnectionInputChanged" />

                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         x:Name="PortTextBox"
                         Header="Port"
                         PlaceholderText="1521"
                         Text="1521"
                         TextChanged="ConnectionInputChanged" />

                <TextBox Grid.Row="1"
                         Grid.Column="0"
                         Grid.ColumnSpan="2"
                         x:Name="ServiceNameTextBox"
                         Header="Service Name"
                         PlaceholderText="ORCLPDB1"
                         TextChanged="ConnectionInputChanged" />

                <TextBox Grid.Row="2"
                         Grid.Column="0"
                         x:Name="UsernameTextBox"
                         Header="Username"
                         TextChanged="ConnectionInputChanged" />

                <PasswordBox Grid.Row="2"
                             Grid.Column="1"
                             x:Name="PasswordBoxControl"
                             Header="Password"
                             PasswordChanged="PasswordBoxControl_PasswordChanged" />
            </Grid>

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        Spacing="12">
                <Button x:Name="TestConnectionButton"
                        Content="Test Connection"
                        Click="TestConnectionButton_Click" />
                <Button x:Name="OpenBrowserButton"
                        Content="Open PeopleCode Interface"
                        Click="OpenBrowserButton_Click"
                        IsEnabled="False" />
            </StackPanel>

            <InfoBar Grid.Row="4"
                     x:Name="InlineErrorInfoBar"
                     IsClosable="False"
                     IsOpen="False"
                     Severity="Error" />

            <Border Grid.Row="5"
                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Status"
                               Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBlock x:Name="StatusSummaryTextBlock"
                               Text="Ready"
                               TextWrapping="WrapWholeWords" />
                    <TextBox x:Name="StatusDetailsTextBox"
                             Text="Enter connection details, then select Test Connection."
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             MinHeight="120"
                             TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
