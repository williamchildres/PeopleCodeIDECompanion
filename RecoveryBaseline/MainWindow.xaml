<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PeopleCodeIDECompanion.RecoveryBaseline.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="PeopleCodeIDECompanion Recovery Baseline">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="#111315">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Background="#252526"
            BorderBrush="#323232"
            BorderThickness="0,0,0,1">
            <Grid Padding="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel
                    Orientation="Horizontal"
                    Spacing="12"
                    VerticalAlignment="Center">
                    <Image
                        Width="16"
                        Height="16"
                        Source="ms-appx:///Assets/Square44x44Logo.scale-200.png" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="#F3F3F3"
                        Text="PeopleCodeIDECompanion" />
                </StackPanel>

                <TextBlock
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Foreground="#A6A6A6"
                    Text="Recovery Shell" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" Padding="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Background="#1B1D1F"
                BorderBrush="#2C2F33"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock
                        FontSize="12"
                        Foreground="#A6A6A6"
                        Text="WORKSPACE" />
                    <TextBlock
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="#F3F3F3"
                        Text="PeopleCode Interface" />
                    <TextBlock
                        FontSize="14"
                        Foreground="#D0D0D0"
                        Text="Overview" />
                    <TextBlock
                        FontSize="14"
                        Foreground="#D0D0D0"
                        Text="Reference Explorer" />
                </StackPanel>
            </Border>

            <Border
                Grid.Column="2"
                Background="#17191B"
                BorderBrush="#2C2F33"
                BorderThickness="1"
                CornerRadius="12"
                Padding="24">
                <StackPanel Spacing="16">
                    <TextBlock
                        FontSize="28"
                        FontWeight="SemiBold"
                        Foreground="#F7F7F7"
                        Text="Recovery Baseline Shell" />
                    <TextBlock
                        MaxWidth="720"
                        Foreground="#D0D0D0"
                        TextWrapping="Wrap"
                        Text="This window is the first migration slice from the existing app. It keeps the packaged WinUI baseline startup path intact while introducing a lightweight shell layout inspired by the current product." />
                    <Border
                        Background="#202326"
                        BorderBrush="#32363B"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock
                                FontSize="12"
                                Foreground="#A6A6A6"
                                Text="PHASE 1 STATUS" />
                            <TextBlock
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="#F3F3F3"
                                Text="Shell only" />
                            <TextBlock
                                Foreground="#D0D0D0"
                                TextWrapping="Wrap"
                                Text="No Oracle connectivity, profile loading, page bootstrapping, or custom title bar behavior has been migrated yet." />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
