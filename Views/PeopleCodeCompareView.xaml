<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PeopleCodeIDECompanion.Views.PeopleCodeCompareView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:PeopleCodeIDECompanion.Models"
    mc:Ignorable="d">

    <Grid Padding="20"
          RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock Text="{x:Bind ViewModel.Title}"
                               Style="{ThemeResource TitleTextBlockStyle}"
                               TextWrapping="WrapWholeWords" />
                    <TextBlock Text="{x:Bind ViewModel.Subtitle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="WrapWholeWords" />
                    <TextBlock Text="{x:Bind ViewModel.DiffSummary}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="WrapWholeWords" />
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="Read-only compare"
                           Style="{ThemeResource BodyStrongTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Grid>

            <InfoBar IsClosable="False"
                     IsOpen="{x:Bind ViewModel.HasDiffNotice, Mode=OneTime}"
                     Severity="Informational"
                     Message="{x:Bind ViewModel.DiffNotice, Mode=OneTime}" />
        </StackPanel>

        <Grid Grid.Row="1"
              ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="{ThemeResource ControlFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <StackPanel Spacing="6">
                    <TextBlock Text="{x:Bind ViewModel.LeftPane.ProfileDisplayName}"
                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                               TextWrapping="WrapWholeWords" />
                    <TextBlock Text="{x:Bind ViewModel.LeftPane.ProfileContext}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="WrapWholeWords" />
                    <TextBlock Text="{x:Bind ViewModel.LeftPane.ObjectType}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.LeftPane.ObjectTitle}"
                               TextWrapping="WrapWholeWords" />
                    <TextBlock Text="{x:Bind ViewModel.LeftPane.ObjectSubtitle}"
                               TextWrapping="WrapWholeWords"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.LeftPane.MetadataSummary}"
                               TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <StackPanel Spacing="6">
                    <TextBlock Text="{x:Bind ViewModel.RightPane.ProfileDisplayName}"
                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                               TextWrapping="WrapWholeWords" />
                    <TextBlock Text="{x:Bind ViewModel.RightPane.ProfileContext}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="WrapWholeWords" />
                    <TextBlock Text="{x:Bind ViewModel.RightPane.ObjectType}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.RightPane.ObjectTitle}"
                               TextWrapping="WrapWholeWords" />
                    <TextBlock Text="{x:Bind ViewModel.RightPane.ObjectSubtitle}"
                               TextWrapping="WrapWholeWords"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.RightPane.MetadataSummary}"
                               TextWrapping="WrapWholeWords" />
                    <InfoBar IsClosable="False"
                             IsOpen="{x:Bind ViewModel.RightPane.HasStatusMessage, Mode=OneTime}"
                             Severity="Warning"
                             Message="{x:Bind ViewModel.RightPane.StatusMessage, Mode=OneTime}" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Background="{ThemeResource ControlFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{x:Bind ViewModel.DiffLines}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:PeopleCodeCompareDiffLineViewModel">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Width="56"
                                           HorizontalTextAlignment="Right"
                                           VerticalAlignment="Top"
                                           Text="{x:Bind LeftLineNumber, Mode=OneTime}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           FontFamily="Consolas" />

                                <Border Grid.Column="1"
                                        Background="{x:Bind LeftBackground, Mode=OneTime}"
                                        Padding="4,2">
                                    <TextBlock Text="{x:Bind LeftText, Mode=OneTime}"
                                               FontFamily="Consolas"
                                               TextWrapping="NoWrap" />
                                </Border>

                                <Border Grid.Column="2"
                                        Background="{ThemeResource CardStrokeColorDefaultBrush}"
                                        Width="1"
                                        HorizontalAlignment="Center" />

                                <TextBlock Grid.Column="3"
                                           Width="56"
                                           HorizontalTextAlignment="Right"
                                           VerticalAlignment="Top"
                                           Text="{x:Bind RightLineNumber, Mode=OneTime}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           FontFamily="Consolas" />

                                <Border Grid.Column="4"
                                        Background="{x:Bind RightBackground, Mode=OneTime}"
                                        Padding="4,2">
                                    <TextBlock Text="{x:Bind RightText, Mode=OneTime}"
                                               FontFamily="Consolas"
                                               TextWrapping="NoWrap" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
