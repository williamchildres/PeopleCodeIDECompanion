<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PeopleCodeIDECompanion.Views.ReadOnlyPlaceholderModeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowSpacing="12"
          ColumnSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <InfoBar x:Name="ComingSoonInfoBar"
                 IsClosable="False"
                 IsOpen="True"
                 Severity="Informational"
                 Message="Read-only Oracle-backed browsing for this object type is coming next. This mode currently shows the intended shell only." />

        <Grid Grid.Row="1"
              ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    MinHeight="420"
                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="BrowsePaneTitleTextBlock"
                               Style="{ThemeResource SubtitleTextBlockStyle}" />

                    <TextBox x:Name="BrowseSearchTextBox"
                             Grid.Row="1" />

                    <ListView x:Name="BrowseListView"
                              Grid.Row="2"
                              IsEnabled="False"
                              SelectionMode="None" />

                    <TextBlock x:Name="BrowsePaneHintTextBlock"
                               Grid.Row="3"
                               TextWrapping="WrapWholeWords"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    MinHeight="420"
                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="ChildPaneTitleTextBlock"
                               Style="{ThemeResource SubtitleTextBlockStyle}" />

                    <TextBox x:Name="ChildSearchTextBox"
                             Grid.Row="1" />

                    <ListView x:Name="ChildListView"
                              Grid.Row="2"
                              IsEnabled="False"
                              SelectionMode="None" />

                    <TextBlock x:Name="ChildPaneHintTextBlock"
                               Grid.Row="3"
                               TextWrapping="WrapWholeWords"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </Grid>
            </Border>

            <Grid Grid.Column="2"
                  RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="ModeTitleTextBlock"
                                   Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <TextBlock x:Name="ModeSubtitleTextBlock"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   TextWrapping="WrapWholeWords" />
                        <TextBlock x:Name="ModeDescriptionTextBlock"
                                   TextWrapping="WrapWholeWords"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Metadata"
                                   Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <TextBlock x:Name="MetadataTitleTextBlock"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   TextWrapping="WrapWholeWords" />
                        <TextBlock x:Name="MetadataSummaryTextBlock"
                                   TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="SourcePaneTitleTextBlock"
                                   Style="{ThemeResource SubtitleTextBlockStyle}" />

                        <ScrollViewer Grid.Row="1"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="SourcePreviewTextBlock"
                                       MinHeight="300"
                                       FontFamily="Consolas"
                                       TextWrapping="NoWrap"
                                       IsTextSelectionEnabled="True" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
