<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PeopleCodeIDECompanion.Views.ReferenceExplorerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:PeopleCodeIDECompanion.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24"
          RowSpacing="16"
          ColumnSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Reference Explorer"
                   Style="{ThemeResource TitleTextBlockStyle}" />

        <AutoSuggestBox Grid.Row="1"
                        PlaceholderText="Search references"
                        TextChanged="SearchBox_TextChanged" />

        <TextBlock Grid.Row="2"
                   Text="{x:Bind ErrorMessage, Mode=OneWay}"
                   Visibility="{x:Bind ErrorMessageVisibility, Mode=OneWay}"
                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                   TextWrapping="WrapWholeWords" />

        <Grid Grid.Row="3"
              ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <ListView ItemsSource="{x:Bind FilteredReferences}"
                          SelectedItem="{x:Bind SelectedReference, Mode=TwoWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ReferenceItem">
                            <StackPanel Padding="12"
                                        Spacing="4">
                                <TextBlock Text="{x:Bind Name}"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="{x:Bind Category}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock Text="No results found"
                           Visibility="{x:Bind NoResultsVisibility, Mode=OneWay}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Style="{ThemeResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </Grid>

            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="12">
                    <TextBlock Text="Details"
                               Style="{ThemeResource SubtitleTextBlockStyle}" />

                    <StackPanel Spacing="4">
                        <TextBlock Text="Name"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="{x:Bind SelectedReference.Name, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Category"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="{x:Bind SelectedReference.Category, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Signature"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="{x:Bind SelectedReference.Signature, Mode=OneWay}"
                                   TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Imports"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="{x:Bind SelectedReference.Imports, Mode=OneWay}"
                                   TextWrapping="WrapWholeWords" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Notes"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="{x:Bind SelectedReference.Notes, Mode=OneWay}"
                                   TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
