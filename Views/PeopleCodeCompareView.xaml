<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PeopleCodeIDECompanion.Views.PeopleCodeCompareView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:PeopleCodeIDECompanion.Models"
    mc:Ignorable="d">

    <Grid Padding="20"
          RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock Text="{x:Bind ViewModel.Title}"
                               Style="{ThemeResource TitleTextBlockStyle}"
                               TextWrapping="WrapWholeWords" />
                    <TextBlock Text="{x:Bind ViewModel.Subtitle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="WrapWholeWords" />
                    <TextBlock Text="{x:Bind ViewModel.DiffSummary}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="WrapWholeWords" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Top">
                    <TextBlock x:Name="DiffNavigationStatusTextBlock"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Button x:Name="PreviousDiffButton"
                            Content="Previous Diff"
                            Click="PreviousDiffButton_Click" />
                    <Button x:Name="NextDiffButton"
                            Content="Next Diff"
                            Click="NextDiffButton_Click" />
                    <TextBlock Text="Read-only compare"
                               VerticalAlignment="Center"
                               Style="{ThemeResource BodyStrongTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Grid>

            <InfoBar IsClosable="False"
                     IsOpen="{x:Bind ViewModel.HasDiffNotice, Mode=OneTime}"
                     Severity="Informational"
                     Message="{x:Bind ViewModel.DiffNotice, Mode=OneTime}" />
        </StackPanel>

        <Grid Grid.Row="1"
              ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="{ThemeResource ControlFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12,12,18,12">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="1"
                                Spacing="6">
                        <TextBlock Text="{x:Bind ViewModel.LeftPane.ProfileDisplayName}"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   TextWrapping="WrapWholeWords" />
                        <TextBlock Text="{x:Bind ViewModel.LeftPane.ProfileContext}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="WrapWholeWords" />
                        <TextBlock Text="{x:Bind ViewModel.LeftPane.ObjectType}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.LeftPane.ObjectTitle}"
                                   TextWrapping="WrapWholeWords" />
                        <TextBlock Text="{x:Bind ViewModel.LeftPane.ObjectSubtitle}"
                                   TextWrapping="WrapWholeWords"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.LeftPane.MetadataSummary}"
                                   TextWrapping="WrapWholeWords" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18,12,12,12">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="56" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="1"
                                Spacing="6">
                        <TextBlock Text="{x:Bind ViewModel.RightPane.ProfileDisplayName}"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   TextWrapping="WrapWholeWords" />
                        <TextBlock Text="{x:Bind ViewModel.RightPane.ProfileContext}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="WrapWholeWords" />
                        <TextBlock Text="{x:Bind ViewModel.RightPane.ObjectType}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.RightPane.ObjectTitle}"
                                   TextWrapping="WrapWholeWords" />
                        <TextBlock Text="{x:Bind ViewModel.RightPane.ObjectSubtitle}"
                                   TextWrapping="WrapWholeWords"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.RightPane.MetadataSummary}"
                                   TextWrapping="WrapWholeWords" />
                        <InfoBar IsClosable="False"
                                 IsOpen="{x:Bind ViewModel.RightPane.HasStatusMessage, Mode=OneTime}"
                                 Severity="Warning"
                                 Message="{x:Bind ViewModel.RightPane.StatusMessage, Mode=OneTime}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2"
              ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="{ThemeResource ControlFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12,12,18,12">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="PeopleCode Source"
                                   Style="{ThemeResource SubtitleTextBlockStyle}" />

                        <Button Grid.Column="1"
                                Content="Copy"
                                Click="CopyLeftButton_Click" />
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  x:Name="LeftSourceScrollViewer"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  ViewChanged="LeftSourceScrollViewer_ViewChanged">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="56" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="LeftLineNumbersTextBlock"
                                       Grid.Column="0"
                                       FontFamily="Consolas"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextAlignment="Right"
                                       TextWrapping="NoWrap" />

                            <RichTextBlock x:Name="LeftSourceRichTextBlock"
                                           Grid.Column="1"
                                           FontFamily="Consolas"
                                           IsTextSelectionEnabled="True"
                                           TextWrapping="NoWrap" />
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18,12,12,12">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="PeopleCode Source"
                                   Style="{ThemeResource SubtitleTextBlockStyle}" />

                        <Button Grid.Column="1"
                                Content="Copy"
                                Click="CopyRightButton_Click" />
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  x:Name="RightSourceScrollViewer"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  ViewChanged="RightSourceScrollViewer_ViewChanged">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="56" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="RightLineNumbersTextBlock"
                                       Grid.Column="0"
                                       FontFamily="Consolas"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextAlignment="Right"
                                       TextWrapping="NoWrap" />

                            <RichTextBlock x:Name="RightSourceRichTextBlock"
                                           Grid.Column="1"
                                           FontFamily="Consolas"
                                           IsTextSelectionEnabled="True"
                                           TextWrapping="NoWrap" />
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
